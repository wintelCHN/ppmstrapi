HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Database — used by scripts/ensure-sequences.js, check-sequence.js, check-perms.js
# Local development
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=b2bcms
DATABASE_USERNAME=strapi_user
DATABASE_PASSWORD=change-me

# Railway runtime / TCP proxy (local --proxy mode)
# DATABASE_URL=postgres://user:pass@host:5432/database
# RAILWAY_PROXY_URL=postgres://user:pass@zephyr.proxy.rlwy.net:40028/railway

# Email notifications (nodemailer — Lead Center)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@b2bcms.com
EMAIL_REPLY_TO=noreply@b2bcms.com
LEAD_NOTIFY_EMAIL=sales@example.com

# Upload provider — local filesystem (default for dev)
# Set to aws-s3 in Railway production to use Cloudflare R2
UPLOAD_PROVIDER=local

# Cloudflare R2 (S3-compatible API) — required in production
# Steps: Cloudflare Dashboard → R2 → Create bucket + API token
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=b2bcms-media
# R2_REGION=auto
# R2_CDN_URL=https://cdn.productsb2b.com

# Strapi Translate — DeepSeek AI Provider (free, uses DeepSeek Chat API)
# Get your API key at https://platform.deepseek.com/
TRANSLATE_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# n8n integration — dedicated token for n8n workflows (createWithImages, blog save, alert/failure)
# Generate a strong random string and use it as Bearer token in n8n HTTP nodes.
N8N_API_TOKEN=your-n8n-integration-token-here
