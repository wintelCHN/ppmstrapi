{
  "collectionName": "components_meta_metadata",
  "info": {
    "name": "Metadata",
    "displayName": "Metadata",
    "icon": "robot"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true
    },
    "metaDescription": {
      "type": "text",
      "required": true
    },
    "metaKeywords": {
      "type": "text",
      "required": false
    },
    "shareImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false,
      "required": false
    },
    "twitterCardType": {
      "type": "enumeration",
      "enum": ["summary", "summary_large_image", "app", "player"],
      "default": "summary"
    },
    "twitterUsername": {
      "type": "string"
    },
    "canonicalOverride": {
      "type": "string",
      "required": false
    },
    "noindex": {
      "type": "boolean",
      "default": false,
      "required": false
    },
    "nofollow": {
      "type": "boolean",
      "default": false,
      "required": false
    },
    "ogTitleOverride": {
      "type": "string",
      "required": false
    },
    "ogDescriptionOverride": {
      "type": "text",
      "required": false
    },
    "articleSection": {
      "type": "string",
      "required": false
    },
    "priority": {
      "type": "decimal",
      "required": false,
      "min": 0.0,
      "max": 1.0
    }
  }
}
