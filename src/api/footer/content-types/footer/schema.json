{
  "kind": "collectionType",
  "collectionName": "footers",
  "info": {
    "singularName": "footer",
    "pluralName": "footers",
    "displayName": "Footer",
    "name": "footer",
    "description": "Per-site footer configuration (one-to-one with Site)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "site": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::site.site",
      "inversedBy": "footer"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "columns": {
      "type": "component",
      "repeatable": true,
      "component": "elements.footer-section",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "bottom_text": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "bottom_links": {
      "type": "component",
      "repeatable": true,
      "component": "links.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "social_links": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
