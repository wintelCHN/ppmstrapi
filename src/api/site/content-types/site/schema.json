{
  "kind": "collectionType",
  "collectionName": "sites",
  "info": {
    "singularName": "site",
    "pluralName": "sites",
    "displayName": "Site",
    "name": "site",
    "description": "Site configuration for multi-site deployment management"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "development"]
    },
    "primary_domain": {
      "type": "string"
    },
    "secondary_domains": {
      "type": "json"
    },
    "deploy_platform": {
      "type": "enumeration",
      "enum": ["vercel", "cloudflare-pages", "netlify"]
    },
    "github_repo": {
      "type": "string"
    },
    "github_branch": {
      "type": "string",
      "default": "main"
    },
    "build_webhook": {
      "type": "string"
    },
    "preview_url": {
      "type": "string"
    },
    "production_url": {
      "type": "string"
    },
    "astro_project_name": {
      "type": "string"
    },
    "seo_default_title": {
      "type": "string"
    },
    "seo_default_description": {
      "type": "text"
    },
    "seo_default_keywords": {
      "type": "text"
    },
    "notes": {
      "type": "blocks"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "site"
    },
    "blogs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog.blog",
      "mappedBy": "site"
    },
    "news_articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::news.news",
      "mappedBy": "site"
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "site"
    },
    "menus": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::menu.menu",
      "mappedBy": "site"
    },
    "footers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::footer.footer",
      "mappedBy": "site"
    }
  }
}
