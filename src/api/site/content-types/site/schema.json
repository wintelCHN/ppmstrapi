{
  "kind": "collectionType",
  "collectionName": "sites",
  "info": {
    "singularName": "site",
    "pluralName": "sites",
    "displayName": "Site",
    "name": "site",
    "description": "Site configuration for multi-site deployment management"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "site_name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid"
    },
    "site_layout": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::site-layout.site-layout",
      "inversedBy": "site"
    },
    "description": {
      "type": "text"
    },
    "lifecycle_state": {
      "type": "enumeration",
      "enum": [
        "development",
        "active",
        "inactive"
      ],
      "default": "development",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "is_published": {
      "type": "boolean",
      "default": false
    },
    "primary_domain": {
      "type": "string"
    },
    "secondary_domains": {
      "type": "json"
    },
    "deploy_platform": {
      "type": "enumeration",
      "enum": [
        "vercel",
        "cloudflare-pages",
        "netlify"
      ]
    },
    "github_repo": {
      "type": "string"
    },
    "github_branch": {
      "type": "string",
      "default": "main"
    },
    "build_webhook": {
      "type": "string"
    },
    "preview_url": {
      "type": "string"
    },
    "production_url": {
      "type": "string"
    },
    "astro_project_name": {
      "type": "string"
    },
    "metadata": {
      "type": "component",
      "repeatable": false,
      "component": "meta.metadata",
      "required": false
    },
    "notes": {
      "type": "blocks"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "site"
    },
    "blogs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog.blog",
      "mappedBy": "site"
    },
    "news_articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::news.news",
      "mappedBy": "site"
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "site"
    },
    "keyword_clusters": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::keyword-cluster.keyword-cluster",
      "mappedBy": "site"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "site"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag",
      "mappedBy": "site"
    }
  }
}
