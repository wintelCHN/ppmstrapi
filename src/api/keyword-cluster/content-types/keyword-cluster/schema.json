{
  "kind": "collectionType",
  "collectionName": "keyword_clusters",
  "info": {
    "singularName": "keyword-cluster",
    "pluralName": "keyword-clusters",
    "displayName": "Keyword Cluster",
    "name": "keyword-cluster",
    "description": "Group keywords by topic and search intent for programmatic SEO"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "primary_keyword": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "secondary_keywords": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "search_intent": {
      "type": "enumeration",
      "enum": [
        "informational",
        "commercial",
        "transactional",
        "comparison"
      ],
      "default": "commercial",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "industry": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "country": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "language": {
      "type": "string",
      "default": "en",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "site": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::site.site",
      "inversedBy": "keyword_clusters"
    },
    "metadata": {
      "type": "component",
      "repeatable": false,
      "component": "meta.metadata",
      "required": false,
      "pluginOptions": {
        "i18n": {
          "localized": true
        },
        "translate": {
          "translate": "translate"
        }
      }
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "keyword_cluster"
    }
  }
}
